{
  "info": {
    "name": "Task Management System",
    "description": "REST API for managing tasks. Built with Spring Boot 4.0.6 and Java 21.\n\nBase URL: http://localhost:8080",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "opencode"
  },
  "item": [
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201 Created\", () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has task ID\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.not.be.undefined;",
                  "    pm.expect(json.title).to.eql(pm.request.body.get('title'));",
                  "});",
                  "",
                  "pm.variables.set(\"taskId\", pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Buy groceries\",\n    \"description\": \"Milk, eggs, bread, butter\",\n    \"status\": \"PENDING\",\n    \"due_date\": \"2026-06-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Creates a new task. `title` and `due_date` are required. `status` defaults to `PENDING` if omitted.\n\n### Validation rules:\n- `title` must not be blank\n- `due_date` must be a valid future date"
          }
        },
        {
          "name": "Create Task — Minimal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Quick task\",\n    \"due_date\": \"2026-07-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Creates a task with only required fields. `status` will default to `PENDING`, `description` will be `null`."
          }
        },
        {
          "name": "Create Task — Validation Error",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"\",\n    \"due_date\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Demonstrates validation errors. Expect a `400 Bad Request` response with field-level error messages."
          }
        },
        {
          "name": "Get Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has task details\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.not.be.undefined;",
                  "    pm.expect(json.title).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Retrieves a task by its ID.\n\n**Run the \"Create Task\" request first** to populate the `taskId` variable."
          }
        },
        {
          "name": "Get Task — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404 Not Found\", () => {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test(\"Response has error message\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.error).to.include(\"Task not found\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/nonexistent-id-12345",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "nonexistent-id-12345"]
            },
            "description": "Attempts to retrieve a task that does not exist. Expects `404 Not Found`."
          }
        },
        {
          "name": "Update Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Task fields updated correctly\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.title).to.eql(\"Updated: Buy groceries\");",
                  "    pm.expect(json.status).to.eql(\"IN_PROGRESS\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated: Buy groceries\",\n    \"description\": \"Milk, eggs, bread, butter, cheese\",\n    \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Partially updates a task. Only the fields included in the request body are changed; omitted fields keep their current values.\n\n**Run the \"Create Task\" request first** to populate the `taskId` variable."
          }
        },
        {
          "name": "Update Task — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404 Not Found\", () => {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Won't work\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/nonexistent-id-12345",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "nonexistent-id-12345"]
            },
            "description": "Attempts to update a non-existent task. Expects `404 Not Found`."
          }
        },
        {
          "name": "Delete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 204 No Content\", () => {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Deletes a task by its ID. Expects `204 No Content` with no response body.\n\n**Run the \"Create Task\" request first** to populate the `taskId` variable.\n\nAfter deletion, a subsequent `GET /tasks/{id}` for this ID should return `404`."
          }
        },
        {
          "name": "Delete Task — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 404 Not Found\", () => {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks/nonexistent-id-12345",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "nonexistent-id-12345"]
            },
            "description": "Attempts to delete a task that does not exist. Expects `404 Not Found`."
          }
        },
        {
          "name": "List All Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Returns all tasks as a flat JSON array, sorted by `due_date` ascending."
          }
        },
        {
          "name": "List Tasks — Filter by Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"All returned tasks have the requested status\", () => {",
                  "    var json = pm.response.json();",
                  "    if (json.length > 0) {",
                  "        json.forEach(task => {",
                  "            pm.expect(task.status).to.eql(\"PENDING\");",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING",
                  "description": "Filter by status: PENDING, IN_PROGRESS, or DONE"
                }
              ]
            },
            "description": "Returns tasks filtered by status as a flat JSON array. Available status values: `PENDING`, `IN_PROGRESS`, `DONE`."
          }
        },
        {
          "name": "List Tasks — Paginated",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is a PageResult object\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('content');",
                  "    pm.expect(json).to.have.property('total_elements');",
                  "    pm.expect(json).to.have.property('total_pages');",
                  "    pm.expect(json).to.have.property('page');",
                  "    pm.expect(json).to.have.property('size');",
                  "    pm.expect(json.page).to.eql(0);",
                  "    pm.expect(json.size).to.eql(2);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=0&size=2",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Zero-based page number"
                },
                {
                  "key": "size",
                  "value": "2",
                  "description": "Number of items per page"
                }
              ]
            },
            "description": "Returns a paginated `PageResult` object with `content`, `total_elements`, `total_pages`, `page`, and `size` fields.\n\n`page` and `size` must both be provided to enable pagination."
          }
        },
        {
          "name": "List Tasks — Filtered + Paginated",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is a PageResult with filtered content\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.content).to.be.an('array');",
                  "    if (json.content.length > 0) {",
                  "        json.content.forEach(task => {",
                  "            pm.expect(task.status).to.eql(\"PENDING\");",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tasks?status=PENDING&page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING",
                  "description": "Filter by status"
                },
                {
                  "key": "page",
                  "value": "0",
                  "description": "Zero-based page number"
                },
                {
                  "key": "size",
                  "value": "5",
                  "description": "Number of items per page"
                }
              ]
            },
            "description": "Combines status filtering and pagination. Returns a `PageResult` object."
          }
        }
      ],
      "description": "All CRUD operations for managing tasks."
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL of the running Task Management API server"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string",
      "description": "Auto-populated task ID from the Create Task response"
    }
  ]
}
